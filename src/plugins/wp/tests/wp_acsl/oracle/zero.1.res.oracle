Assume {
  Type: is_uint32(i).
  (* Heap *)
  Type: (region(s.base) <= 0) /\ linked(Malloc_0).
  (* Goal *)
  When: (0 <= i_1) /\ (i_1 < x).
  (* Pre-condition *)
  Have: valid_rw(Malloc_0, a, 10).
  (* Invariant *)
  Have: (0 <= i) /\ (i <= 10).
  (* Invariant 'is_zero' *)
  Have: forall i_2 : Z. ((0 <= i_2) -> ((i_2 < i) ->
      (a_1[shift_float64(s, i_2)] = 0))).
  (* Then *)
  Have: i <= 9.
  (* Invariant *)
  Have: x <= 10.
}
Prove: a_1[shift_float64(s, i) <- .0][shift_float64(s, i_1)] = 0.

