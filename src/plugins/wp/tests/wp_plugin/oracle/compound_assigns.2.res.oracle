Cluster Matrix {
  
  Predicate EqArray_int (n_0 : int) (T_0 : int[]) (T_1 : int[])
    = forall i_0:int. (0<=i_0) -> (i_0<n_0) -> (T_1[i_0]=T_0[i_0])
  
  Predicate IsArray_sint32 (T_0 : int[])
