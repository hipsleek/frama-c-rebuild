}

Cluster MemBytes.Float {
  
  Function int_to_float64 (f_5 : int) : f64
  
  Function float64_to_int (f_4 : f64) : int
  
  Axiom encode_bounds_float64:
    forall f_7: f64.
    (is_uint64 (float64_to_int f_7))
  
  Axiom decode_encode_float64:
    forall f_6: f64.
    (int_to_float64 (float64_to_int f_6))=f_6
  
  Axiom encode_decode_float64:
    forall i_1: int.
    (float64_to_int (int_to_float64 i_1))=i_1
  
}

Cluster MemBytes.PointersProperties {
  
  Predicate framed (m_0 : int[][])
    = forall a_0:addr.
      ((region (base a_0))<=0)
      -> ((region (base (addr_of_int (read_uint64 m_0 a_0))))<=0)
  
  Axiom pointers_int_range:
    forall a_1: addr.
    (statically_allocated (base a_1)) -> (is_uint64 (int_of_addr a_1))
  
}

Cluster S1_A {
  
  Type S1_A = { F1_A_f : int[]; F1_A_g : f64; }
  
  Predicate EqS1_A (S_0 : S1_A) (S_1 : S1_A)
    = (S_1.F1_A_g=S_0.F1_A_g) /\ (EqArray_int 4 S_0.F1_A_f S_1.F1_A_f)
  
  Predicate IsS1_A (S_0 : S1_A) = (IsArray_sint32 S_0.F1_A_f)
  
}

Cluster Shifts {
  
  Function shiftfield_F1_A_g (p_1 : addr) : addr = (shift p_1 16)
  
  Function shift_sint32 (p_0 : addr) (k_0 : int) : addr = (shift p_0 (4*k_0))
  
  Function shiftfield_F1_A_f (p_0 : addr) : addr = (shift p_0 0)
  
}

