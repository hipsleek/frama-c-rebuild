Let x = 4 * n.
Let a_2 = memcpy(M0002_sint32_0, a_1, M0002_sint32_undef_0, a_1, x).
Let a_3 = memcpy(M0002_sint32_0, a_1, M0002_sint32_undef_0, a_1, 4 * i).
Assume {
  Type: is_sint32(i) /\ is_sint32(n).
  (* Heap *)
  Type: (region(a.base) <= 0) /\ (region(b.base) <= 0).
  (* Goal *)
  When: (0 <= i_1) /\ (i_1 < n).
  (* Pre-condition *)
  Have: separated(a_1, x, shift_sint32(b, 0), x).
  (* Invariant 'Range' *)
  Have: 0 <= n.
  (* Invariant 'Range' *)
  Have: (0 <= i) /\ (i <= n).
  (* Invariant 'Copy' *)
  Have: forall i_2 : Z. ((0 <= i_2) -> ((i_2 < i) ->
      (a_2[shift_sint32(b, i_2)] = a_2[shift_sint32(a, i_2)]))).
  (* Else *)
  Have: n <= i.
}
Prove: a_3[shift_sint32(b, i_1)] = a_3[shift_sint32(a, i_1)].

