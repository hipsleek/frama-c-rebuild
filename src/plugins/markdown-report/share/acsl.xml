<language name="ACSL" version="1" extensions="*.acsl"
          section="Sources" kateversion="2.4">
<highlighting>
<list name="keywords">
<item>allocates</item>
<item>assert</item>
<item>assigns</item>
<item>assumes</item>
<item>axiom</item>
<item>axiomatic</item>
