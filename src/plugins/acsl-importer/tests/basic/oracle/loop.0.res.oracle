/* Generated by Frama-C */
extern int f_extern(int i);

int while1(int m, int v)
{
  int i = 0;
  int r = 0;
  if (r < v) 
    if (i < m) 
      /*@ loop invariant i ≥ 0 ∧ i < m; */
      while (1) {
        {
          r = f_extern(i);
          i ++;
        }
        if (r < v) {
          if (! (i < m)) break;
        }
        else break;
      }
  return r;
}

int sum(int a, int b)
{
  int i = 0;
  int r = 0;
  /*@ loop invariant i ≤ a; */
  while (1) {
    {
      r ++;
      i ++;
    }
    if (! (i < a)) break;
  }
  {
    int j = 0;
    if (j < b) 
      /*@ loop invariant j ≤ b; */
      while (1) {
        {
          r ++;
          j ++;
        }
        if (! (j < b)) break;
      }
  }
  return r;
}

