int f(int i);

/*@ assigns \nothing; */
int g(int j);

void job(int *t, int A)
{
  /*@ assert 50 ≤ A ≤ 100; */
  {
    int i = 0;
    /*@ requires i ≡ 0;
        ensures i ≡ 50; */
    /*@ loop invariant 0 ≤ i ≤ 50;
        loop invariant ∀ ℤ k; 0 ≤ k < i ⇒ P(*(t + k));
        loop assigns i, *(t + (0 .. 49));
    */
    while (i < 50) {
      /*@ ensures i ≡ \old(i); */
      {
        /*@ ensures P(phi(C(*(t + i)))); */
        *(t + i) = f(i);
      }
      i ++;
    }
  }
  {
    int j = A;
    /*@ \eva::slevel 100; */
    /*@ loop invariant A ≤ j ≤ 100;
        loop assigns j, *(t + (A .. 99)); */
    while (j < 100) {
      {
        *(t + j) = g(j);
      }
      j ++;
    }
  }
  /*@ assert ∀ ℤ k; 0 ≤ k < 50 ⇒ P(*(t + k)); */
  return;
}

int T[100];
void main(void)
{
  job(T,50);
