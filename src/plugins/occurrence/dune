(rule
 (alias frama-c-configure)
 (deps (universe))
 (action (progn
          (echo "Occurrence:" %{lib-available:frama-c-occurrence.core} "\n")
          (echo "  - Eva:" %{lib-available:frama-c-eva.core} "\n")
  )
  )
)

(rule
 (alias install)
 (enabled_if
  (and
   (= %{env:FRAMAC_DEVELOPER=no} "yes")
   (not %{lib-available:frama-c-occurrence.core})))
 (action (echo "WARNING: Occurrence disabled. Run 'dune build @frama-c-configure' for more details\n"))
)

( library
  (name occurrence)
  (optional)
  (public_name frama-c-occurrence.core)
  (flags -open Frama_c_kernel :standard -w -9)
  (libraries frama-c.kernel frama-c-eva.core)
  (instrumentation (backend landmarks))
  (instrumentation (backend bisect_ppx))
)

(plugin (optional) (name occurrence) (libraries frama-c-occurrence.core) (site (frama-c plugins)))
