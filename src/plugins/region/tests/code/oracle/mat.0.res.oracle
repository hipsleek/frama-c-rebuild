[kernel] Parsing mat.c (with preprocessing)
[region] Function BornatArrayStyle:
  R0001: ---A X[12] 128b { .re: R0002; #64b; } ;
  R0002: -R-- (double) 64b ;
  R0003: -R-- i (int) 32b (singleton) ;
  R0004: -R-- j (int) 32b (singleton) ;
  R0005: -R-- k (int) 32b (singleton) ;
  R0006: IR-- c (struct Complex *) 64b (*R0001) (singleton) (allocated) ;
  R0007: I--- p (double) 64b (singleton) (allocated) ;
[region] annotating function BornatArrayStyle
