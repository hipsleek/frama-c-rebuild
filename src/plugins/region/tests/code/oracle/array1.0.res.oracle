[kernel] Parsing array1.i (no preprocessing)
[region] Function job:
  R0001: -R-- n (int) 32b (singleton) ;
  R0002: -R-- p (int *) 64b (*R0003) (singleton) ;
  R0003: -R-A (int) 32b p[0..n - 1] q[0..n - 1] ;
  R0004: -R-- q (int *) 64b (*R0003) (singleton) ;
  R0005: IRW- s (int) 32b (singleton) (allocated) ;
  R0006: IRW- k (int) 32b (singleton) (allocated) ;
  R0007: --W- \result (int) 32b ;
[region] annotating function job
